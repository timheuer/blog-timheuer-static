---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutBox from '../components/AboutBox.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Build a JSON-safe posts-by-date structure for client-side JS
const postsData: Record<string, { title: string; slug: string }[]> = {};
for (const post of sorted) {
  const d = post.data.pubDate;
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  if (!postsData[key]) postsData[key] = [];
  postsData[key].push({ title: post.data.title, slug: post.data.slug });
}

// Find the month of the most recent post for default view
const latestDate = sorted[0]?.data.pubDate ?? new Date();
const defaultYear = latestDate.getFullYear();
const defaultMonth = latestDate.getMonth();
---

<BaseLayout title="Archive - Tim Heuer" description="Browse posts by date">
  <article class="post container">
    <div id="calendar-app">
      <div class="cal-toolbar">
        <div class="cal-toolbar-left">
          <button id="btn-today" class="cal-btn">Today</button>
          <button id="btn-prev" class="cal-btn cal-nav">&lsaquo;</button>
          <button id="btn-next" class="cal-btn cal-nav">&rsaquo;</button>
        </div>
        <span id="cal-title" class="cal-title"></span>
      </div>
      <div class="cal-shell" role="grid" aria-labelledby="cal-title">
        <div class="cal-weekdays" role="row">
          <div role="columnheader">Sunday</div>
          <div role="columnheader">Monday</div>
          <div role="columnheader">Tuesday</div>
          <div role="columnheader">Wednesday</div>
          <div role="columnheader">Thursday</div>
          <div role="columnheader">Friday</div>
          <div role="columnheader">Saturday</div>
        </div>
        <div id="cal-body" class="cal-grid"></div>
      </div>
      <div id="cal-posts" class="cal-posts"></div>
    </div>
    <AboutBox />
  </article>

  <script define:vars={{ postsData, defaultYear, defaultMonth }}>
    const posts = postsData;
    let currentYear = defaultYear;
    let currentMonth = defaultMonth;

    const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
      'July', 'August', 'September', 'October', 'November', 'December'];

    function pad(n) { return String(n).padStart(2, '0'); }
    function dateKey(y, m, d) { return `${y}-${pad(m + 1)}-${pad(d)}`; }

    function render() {
      document.getElementById('cal-title').textContent = `${monthNames[currentMonth]}, ${currentYear}`;

      const firstDay = new Date(currentYear, currentMonth, 1).getDay();
      const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();

      // Previous month info for leading days
      const prevMonth = currentMonth === 0 ? 11 : currentMonth - 1;
      const prevYear = currentMonth === 0 ? currentYear - 1 : currentYear;
      const daysInPrevMonth = new Date(prevYear, prevMonth + 1, 0).getDate();

      const calendarGrid = document.getElementById('cal-body');
      calendarGrid.innerHTML = '';

      let day = 1;
      let nextDay = 1;
      const totalCells = Math.ceil((firstDay + daysInMonth) / 7) * 7;

      calendarGrid.style.setProperty('--calendar-rows', String(totalCells / 7));

      for (let cellIndex = 0; cellIndex < totalCells; cellIndex++) {
        const dayCell = document.createElement('div');
        dayCell.className = 'cal-day';
        dayCell.setAttribute('role', 'gridcell');

        if (cellIndex < firstDay) {
          // Previous month days
          const d = daysInPrevMonth - firstDay + cellIndex + 1;
          dayCell.classList.add('cal-other-month');
          dayCell.innerHTML = `<span class="cal-day-num">${pad(d)}</span>`;
        } else if (day <= daysInMonth) {
          const key = dateKey(currentYear, currentMonth, day);
          const dayPosts = posts[key];
          dayCell.innerHTML = `<span class="cal-day-num">${pad(day)}</span>`;
          if (dayPosts) {
            dayCell.classList.add('cal-has-posts');
            const list = document.createElement('div');
            list.className = 'cal-cell-posts';
            for (const post of dayPosts) {
              const a = document.createElement('a');
              a.href = `/blog/${post.slug}/`;
              a.textContent = post.title;
              a.title = post.title;
              list.appendChild(a);
            }
            dayCell.appendChild(list);
          }
          day++;
        } else {
          // Next month days
          dayCell.classList.add('cal-other-month');
          dayCell.innerHTML = `<span class="cal-day-num">${pad(nextDay)}</span>`;
          nextDay++;
        }

        calendarGrid.appendChild(dayCell);
      }

      // Posts list below calendar
      const postsDiv = document.getElementById('cal-posts');
      const monthPosts = [];
      for (let d = 1; d <= daysInMonth; d++) {
        const key = dateKey(currentYear, currentMonth, d);
        if (posts[key]) {
          for (const p of posts[key]) {
            monthPosts.push({ day: d, ...p });
          }
        }
      }
      if (monthPosts.length > 0) {
        postsDiv.innerHTML = `<h3>Posts in ${monthNames[currentMonth]} ${currentYear}</h3><ul>` +
          monthPosts.map(p => `<li><span class="cal-post-date">${monthNames[currentMonth].slice(0,3)} ${p.day}</span> &ndash; <a href="/blog/${p.slug}/">${p.title}</a></li>`).join('') +
          '</ul>';
      } else {
        postsDiv.innerHTML = `<p class="cal-no-posts">No posts in ${monthNames[currentMonth]} ${currentYear}</p>`;
      }
    }

    document.getElementById('btn-prev').addEventListener('click', () => {
      currentMonth--;
      if (currentMonth < 0) { currentMonth = 11; currentYear--; }
      render();
    });
    document.getElementById('btn-next').addEventListener('click', () => {
      currentMonth++;
      if (currentMonth > 11) { currentMonth = 0; currentYear++; }
      render();
    });
    document.getElementById('btn-today').addEventListener('click', () => {
      const now = new Date();
      currentYear = now.getFullYear();
      currentMonth = now.getMonth();
      render();
    });

    render();
  </script>

  <style>
    #calendar-app {
      margin-top: 1rem;
    }
    .cal-toolbar {
      display: flex;
      align-items: center;
      position: relative;
      margin-bottom: 0;
      padding: 8px 4px;
      border: 1px solid #ddd;
      border-bottom: none;
      background: #f9f9f9;
    }
    .cal-toolbar-left {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .cal-btn {
      background: #e8e8e8;
      border: 1px solid #ccc;
      padding: 4px 12px;
      cursor: pointer;
      font-size: 0.85rem;
      border-radius: 3px;
      color: #333;
      min-height: 32px;
      line-height: 1;
    }
    .cal-btn:hover {
      background: #ddd;
    }
    .cal-nav {
      font-size: 1.1rem;
      padding: 4px 8px;
      font-weight: bold;
      width: 32px;
    }
    .cal-title {
      font-size: 1.1rem;
      font-weight: 600;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      text-align: center;
    }
    .cal-shell {
      width: 100%;
      border: 1px solid #ddd;
      border-right: none;
      border-bottom: none;
    }
    .cal-weekdays {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
    }
    .cal-weekdays > div {
      background: #f5f5f5;
      border-right: 1px solid #ddd;
      border-bottom: 1px solid #ddd;
      padding: 8px;
      text-align: center;
      font-weight: 600;
      font-size: 0.85rem;
    }
    .cal-grid {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      grid-template-rows: repeat(var(--calendar-rows, 5), 90px);
    }
    :global(.cal-day) {
      border-right: 1px solid #ddd;
      border-bottom: 1px solid #ddd;
      height: 90px;
      padding: 4px 6px;
      font-size: 0.85rem;
      overflow: hidden;
      position: relative;
      min-width: 0;
      white-space: normal;
    }
    :global(.cal-day-num) {
      display: block;
      text-align: right;
      font-weight: 500;
      margin-bottom: 0;
    }
    :global(.cal-other-month) {
      background: #f0f0f0;
      color: #aaa;
    }
    :global(.cal-has-posts) {
      background: #faf8ff;
    }
    :global(.cal-cell-posts) {
      position: absolute;
      left: 4px;
      right: 4px;
      top: 24px;
      bottom: 4px;
      display: flex;
      flex-direction: column;
      gap: 2px;
      overflow: hidden;
    }
    :global(.cal-cell-posts a) {
      font-size: 0.7rem;
      line-height: 1.3;
      color: #fff;
      text-decoration: none;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      display: block;
      background: #512bd4;
      padding: 1px 5px;
      border-radius: 3px;
      min-width: 0;
    }
    :global(.cal-cell-posts a:hover) {
      background: #3d1fa3;
    }
    .cal-posts {
      margin-top: 1.5rem;
    }
    .cal-posts h3 {
      margin-bottom: 0.5rem;
    }
    .cal-posts ul {
      list-style: none;
      padding: 0;
    }
    :global(.cal-posts li) {
      padding: 4px 0;
      border-bottom: 1px solid #eee;
    }
    :global(.cal-post-date) {
      color: #666;
      font-size: 0.85rem;
      display: inline-block;
      min-width: 3.5em;
    }
    :global(.cal-posts a) {
      color: #512bd4;
    }
    :global(.cal-no-posts) {
      color: #999;
      font-style: italic;
    }
  </style>
</BaseLayout>
